# Google Search Console verification meta tag value
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification meta tag value
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Note: Google Analytics Measurement ID (G-0R77Z2VFWT) is hardcoded in
# src/components/GoogleAnalytics.tsx — no env var needed.

# Base URL for the Ask AI API (src/components/AskAI.tsx). Leave unset in
# production — the API is served same-origin at deniskim1.com/api/ask.
# For local `next dev` against `npx wrangler dev`, uncomment:
# NEXT_PUBLIC_ASK_API_BASE=http://localhost:8787
