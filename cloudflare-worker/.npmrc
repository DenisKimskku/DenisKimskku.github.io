# wrangler@4 declares an OPTIONAL peer on @cloudflare/workers-types@^4, but this
# worker uses the newer @^5 types. The peer is optional and types-only (not
# needed to `wrangler deploy`), so tell npm to install through the version
# mismatch instead of failing `npm ci` in CI on the ERESOLVE.
legacy-peer-deps=true
